int main() {
    std::cout << "=== Демонстрация ===\n\n";

    // IP
    SlpAddress ip("192.168.1.100"), net("192.168.1.0"), mask("255.255.255.0");
    std::cout << "IP: " << ip << "\n";
    std::cout << "В сети 192.168.1.0/24? " << (ip.inNetwork(net,mask)?"ДА":"НЕТ") << "\n";
    std::cout << "Sum<IP>(0.0.0.1, 0.0.0.2) = " << Sum(SlpAddress(0,0,0,1), SlpAddress(0,0,0,2)) << "\n\n";

    // Телефоны
    std::vector<std::string> nums = {
        "+7 (999) 123-45-67", "8-916-555-12-34", "+7_999_123_45_67",
        "+44 20 7946 0958", "+380501234567"
    };
    for (auto& s : nums) {
        try {
            PhoneNumber p(s);
            std::cout << s << " → " << p.ToString() << " [" << p.country << "]\n";
        } catch (std::exception& e) {
            std::cout << s << " → ОШИБКА: " << e.what() << "\n";
        }
    }
    std::cout << "\n";

    // Тесты
    std::cout << "=== Тесты ===\n";
    std::cout << "Итого: " << passed << " passed, " << failed << " failed\n";

    return failed ? 1 : 0;
}
